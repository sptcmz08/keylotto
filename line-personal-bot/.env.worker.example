# Windows LINE Desktop Automation Worker

WORKER_HOST=127.0.0.1
WORKER_PORT=5001
WORKER_API_TOKEN=change-me
WORKER_LINE_WINDOW_TITLE_REGEX=.*LINE.*

# Relative coordinates from the top-left corner of the LINE window
WORKER_SEARCH_BOX_X=120
WORKER_SEARCH_BOX_Y=120
WORKER_MESSAGE_BOX_X=420
WORKER_MESSAGE_BOX_Y=760
WORKER_ATTACH_BUTTON_X=360
WORKER_ATTACH_BUTTON_Y=760

WORKER_AFTER_FOCUS_DELAY=0.6
WORKER_AFTER_SEARCH_DELAY=1.0
WORKER_AFTER_OPEN_CHAT_DELAY=0.8
WORKER_AFTER_TEXT_DELAY=0.3
WORKER_AFTER_ATTACH_DELAY=1.2
WORKER_AFTER_IMAGE_SEND_DELAY=1.2

AUTOMATION_TEMP_DIR=automation
