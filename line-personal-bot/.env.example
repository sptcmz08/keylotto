# LINE Personal Bot Configuration
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่า

# API Settings
API_HOST=0.0.0.0
API_PORT=5000

# LINE Personal Account Settings
# หมายเหตุ: ต้อง login ด้วย QR Code ครั้งแรกก่อนใช้งาน
LINE_PERSONAL_ENABLED=true

# Session file (จะสร้างอัตโนมัติหลัง login)
SESSION_FILE=line_session.pkl

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/line-bot/app.log

# CORS (อนุญาตให้ PHP เข้าถึง)
# ใส่ domain ของคุณ เช่น https://imzshop97.com
ALLOWED_ORIGINS=http://localhost,https://imzshop97.com,http://imzshop97.com
