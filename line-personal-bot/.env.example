# LINE Personal Bot Configuration

API_HOST=0.0.0.0
API_PORT=5000

# Real personal-account sending is done by a logged-in LINE Desktop worker.
LINE_PERSONAL_ENABLED=true
LINE_SEND_MODE=automation
AUTOMATION_WORKER_URL=http://127.0.0.1:5001
AUTOMATION_WORKER_TOKEN=change-me
AUTOMATION_WORKER_TIMEOUT=60
AUTOMATION_VERIFY_SSL=false

# Kept for API compatibility only; LINE login stays on the worker machine.
SESSION_FILE=line_session.pkl
SETTINGS_FILE=settings.json

LOG_LEVEL=INFO
LOG_FILE=logs/app.log

ALLOWED_ORIGINS=http://localhost,https://imzshop97.com,http://imzshop97.com
