# ============================================
# .htaccess — Subdomain routing for IMZ Shop 97
# ============================================
# ⚠ ยังไม่เปิดใช้งาน: ต้องตั้งค่า DNS ก่อน
# วิธีเปิดใช้งาน:
# 1. ไปที่ Plesk > DNS Settings
# 2. เพิ่ม A Record: agent.imzshop97.com → IP เดิม
# 3. เพิ่ม A Record: member.imzshop97.com → IP เดิม
# 4. แล้ว uncomment ส่วนด้านล่างนี้
# ============================================

# <IfModule mod_rewrite.c>
# RewriteEngine On
#
# # agent.imzshop97.com → /admin/
# RewriteCond %{HTTP_HOST} ^agent\. [NC]
# RewriteCond %{REQUEST_URI} !^/admin/ [NC]
# RewriteRule ^(.*)$ /admin/$1 [L]
#
# # member.imzshop97.com → block admin access
# RewriteCond %{HTTP_HOST} ^member\. [NC]
# RewriteCond %{REQUEST_URI} ^/admin/ [NC]
# RewriteRule ^admin/(.*)$ / [R=302,L]
# </IfModule>
